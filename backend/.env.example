# Server
PORT=4002
NODE_ENV=development

# Database
DATABASE_URL="file:./dev.db"

# Upstream currency API (free, no key). Base is appended as /<BASE> at request time.
CURRENCY_API_BASE="https://open.er-api.com/v6/latest"

# Cache TTL in seconds
CACHE_TTL=3600

# Rate limit
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=900000
